# Application
APP_NAME=ai-evaluation-service
APP_VERSION=1.0.0
DEBUG=false

# Database
# DATABASE_URL: Transaction pooler connection (PgBouncer port 6543) for running app
# This is the connection used by the FastAPI application
DATABASE_URL=postgresql://user:password@localhost:6543/ai_evaluation

# DATABASE_URL_MIGRATIONS: Direct connection (port 5432) for Alembic DDL operations
# DDL (CREATE TABLE, ALTER TABLE, etc.) should NOT go through transaction pooler
# If not set, falls back to DATABASE_URL
DATABASE_URL_MIGRATIONS=postgresql://user:password@localhost:5432/ai_evaluation

DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20

# LLM Provider
LLM_PROVIDER=openai
OPENAI_API_KEY=your_openai_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here
CLAUDE_API_KEY=your_claude_api_key_here
LLM_MODEL=gpt-4
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=2000
LLM_MAX_TOKENS_RESUME_PARSING=8000
LLM_TIMEOUT=60

# Embeddings
EMBEDDING_PROVIDER=openai
VECTOR_BACKEND=pgvector  # pgvector or qdrant
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSION=1536
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
PGVECTOR_CONNECTION_STRING=postgresql://user:password@localhost:5432/ai_evaluation

# JWT/Auth
JWT_SECRET_KEY=your_jwt_secret_key_here
JWT_ALGORITHM=HS256
SERVICE_TOKEN=your_service_token_here

# Feature Flags
ENABLE_AI_INTERVIEW=true
ENABLE_FITMENT_SCORING=true
ENABLE_RESUME_SCREENING=true

# Thresholds
CONFIDENCE_THRESHOLD=0.7
FITMENT_SCORE_THRESHOLD=0.6
