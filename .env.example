# Application
APP_NAME=ai-evaluation-service
APP_VERSION=1.0.0
DEBUG=false

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/ai_evaluation
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20

# LLM Provider
LLM_PROVIDER=openai
OPENAI_API_KEY=your_openai_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here
CLAUDE_API_KEY=your_claude_api_key_here
LLM_MODEL=gpt-4
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=2000
LLM_TIMEOUT=60

# Embeddings
EMBEDDING_PROVIDER=openai
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSION=1536
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
PGVECTOR_CONNECTION_STRING=postgresql://user:password@localhost:5432/ai_evaluation

# Kafka
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_GROUP_ID=ai-evaluation-service
KAFKA_AUTO_OFFSET_RESET=earliest

# JWT/Auth
JWT_SECRET_KEY=your_jwt_secret_key_here
JWT_ALGORITHM=HS256

# Feature Flags
ENABLE_AI_INTERVIEW=true
ENABLE_FITMENT_SCORING=true
ENABLE_RESUME_SCREENING=true

# Thresholds
CONFIDENCE_THRESHOLD=0.7
FITMENT_SCORE_THRESHOLD=0.6
